# Load machine-local secrets if present. This file is untracked and lives
# outside the Nix store; populate it with `make secrets/restore`.
[[ -f "${XDG_CONFIG_HOME:-$HOME/.config}/secrets.env" ]] && \
    source "${XDG_CONFIG_HOME:-$HOME/.config}/secrets.env"

if ! ssh-add -l > /dev/null 2>&1; then
    echo "No SSH identities found. Adding key..."
    ssh-add

    if [ $? -eq 0 ]; then
        echo "SSH key added successfully."
    else
        echo "Failed to add SSH key."
    fi
fi
