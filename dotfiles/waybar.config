// vim:ft=json

{
  "modules-left": ["sway/workspaces"],
  "modules-center": ["cpu", "temperature", "memory", "network"],
  "modules-right": ["pulseaudio", "battery", "clock"],
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
  },
  "clock": {
    "format": "{:%a, %d. %b  %H:%M}"
  },
  "cpu": {
    "interval": 10,
    "format": "{}% ´őŤ",
    "max-length": 10
  },
  "memory": {
    "interval": 30,
    "format": "{used:0.1f}G/{total:0.1f}G ´âë"
  },
  "network": {
    "interface": "wlp3s0",
    "format": "{ifname}",
    "format-wifi": "{essid} ({signalStrength}%) ´çź",
    "format-ethernet": "{ifname} ´âü",
    "format-disconnected": "", //An empty format will hide the module.
    "tooltip-format": "{ifname}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ´çź",
    "tooltip-format-ethernet": "{ifname} ´âü",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}´Őö",
    "format-muted": "´ÇŽ",
    "format-icons": {
      "headphone": "´Çą",
      "hands-free": "´ľÉ",
      "headset": "´ľÉ",
      "phone": "´éĽ",
      "portable": "´éĽ",
      "car": "´ć╣",
      "default": ["´Çž", "´ÇĘ"]
    },
    "scroll-step": 1,
    "on-click": "pavucontrol"
  },
  "temperature": {
    "format": "{temperatureC}┬░C ´őë"
  }
}
